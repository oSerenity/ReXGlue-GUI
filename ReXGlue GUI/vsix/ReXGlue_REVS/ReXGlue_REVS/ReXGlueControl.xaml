<UserControl x:Class="ReXGlue_REVS.ReXGlueControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="380" d:DesignWidth="320"
             Background="#252526">
    <UserControl.Resources>
        <!-- Force button colors so VS theme does not override -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#707070"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#252526"/>
                                <Setter Property="Foreground" Value="#5A5A5A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ComboBox dropdown: VS host often uses light popup with invisible gray text -->
        <Style x:Key="ReXGlueComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#0D0D0D"/>
            <Setter Property="Background" Value="#F2F2F2"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#0E639C"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0" Background="#252526">
        <StackPanel Margin="12,12,12,16" VerticalAlignment="Top">
            <!-- TOML -->
            <TextBlock Text="TOML config" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4"/>
            <Border Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1" Padding="8,6" Margin="0,0,0,4">
                <TextBlock x:Name="textTomlPath" Text="Not set" Foreground="#9E9E9E" FontSize="11" TextWrapping="Wrap" ToolTip="Path to ReXGlue TOML for this solution"/>
            </Border>
            <TextBlock x:Name="textFunctionCount" Text="[functions]: —" Foreground="#6E6E6E" FontSize="11" Margin="0,0,0,8"/>
            <Button x:Name="buttonSetToml" Content="Set TOML Path (Solution)" Click="ButtonSetToml_Click" Margin="0,0,0,8"
                    Height="28" Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>

            <!-- TOML editor -->
            <TextBlock Text="TOML editor" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button x:Name="buttonReload" Content="Reload" Click="ButtonReload_Click" Margin="0,0,6,0"
                        Height="24" Width="60" Background="#3F3F46" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="buttonSave" Content="Save" Click="ButtonSave_Click"
                        Height="24" Width="60" Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
            <!-- Toolbar: same as desktop -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4" x:Name="panelToolbar">
                <Button x:Name="buttonAddSetjmp" Content="+ setjmp/longjmp" Click="ButtonAddSetjmp_Click" Margin="0,0,4,0" Height="24" Background="#3F3F46" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="buttonRemoveDupes" Content="Remove Dupes" Click="ButtonRemoveDupes_Click" Margin="0,0,4,0" Height="24" Background="#3F3F46" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="buttonStripCtxCtr" Content="Strip ctx.ctr labels" Click="ButtonStripCtxCtr_Click" Margin="0,0,4,0" Height="24" Background="#3F3F46" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand"
                        ToolTip="Remove trailing # ctx.ctr.u32[n] comments from all lines"/>
                <Button x:Name="buttonClearValues" Content="Clear Values" Click="ButtonClearValues_Click" Margin="0,0,4,0" Height="24" Background="#3F3F46" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="buttonWriteFunctions" Content="Write [functions]" Click="ButtonWriteFunctions_Click" Margin="0,0,4,0" Height="24" Background="#3F3F46" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="buttonAddAddr" Content="Add addr = {}" Click="ButtonAddAddr_Click" Margin="0,0,4,0" Height="24" Background="#3F3F46" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="buttonWriteRexcrt" Content="Write [rexcrt]" Click="ButtonWriteRexcrt_Click" Height="24" Background="#3F3F46" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
            <!-- Starter templates (desktop chips) -->
            <TextBlock Text="Starter:" Foreground="#888888" FontSize="11" Margin="0,2,0,2"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="= {}" Click="ButtonStarter_Click" Tag="= {}" Margin="0,0,4,0" Height="22" Background="#2A2A2A" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand" FontFamily="Consolas" FontSize="11"/>
                <Button Content="= { name, size }" Click="ButtonStarter_Click" Tag="= { name = &quot;rex_sub_%ADDR%&quot;, size = 0x0 }" Margin="0,0,4,0" Height="22" Background="#2A2A2A" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand" FontFamily="Consolas" FontSize="11"/>
                <Button Content="= { parent, size }" Click="ButtonStarter_Click" Tag="= { parent = 0x00000000, size = 0x0 }" Height="22" Background="#2A2A2A" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand" FontFamily="Consolas" FontSize="11"/>
            </StackPanel>
            <Border Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1" Margin="0,0,0,8" MinHeight="160">
                <RichTextBox x:Name="richTextBoxToml" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11" Padding="6"
                             Background="#1E1E1E" Foreground="#CCCCCC" CaretBrush="#CCCCCC" BorderThickness="0"
                             TextChanged="RichTextBoxToml_TextChanged"/>
            </Border>
            <!-- Backup -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="buttonSaveBackup" Content="Save Backup" Click="ButtonSaveBackup_Click" Margin="0,0,6,0" Height="24" Background="#3F3F46" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="buttonLoadBackup" Content="Load Backup" Click="ButtonLoadBackup_Click" Height="24" Background="#3F3F46" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>

            <!-- Code generation -->
            <TextBlock Text="Code generation" Foreground="#CCCCCC" FontSize="12" Margin="0,12,0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <CheckBox x:Name="checkCodegenForce" Content="--force" Foreground="#D4D4D4" Margin="0,0,12,0" VerticalAlignment="Center"
                          Checked="CodegenOption_Changed" Unchecked="CodegenOption_Changed"/>
                <CheckBox x:Name="checkCodegenExHandlers" Content="--enable_exception_handlers" Foreground="#D4D4D4" Margin="0,0,12,0" VerticalAlignment="Center"
                          Checked="CodegenOption_Changed" Unchecked="CodegenOption_Changed"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Log level:" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="comboCodegenLogLevel" Width="120" Height="26" SelectionChanged="ComboCodegenLogLevel_SelectionChanged"
                          Background="#3F3F46" Foreground="#F0F0F0" BorderBrush="#707070" Padding="6,2"
                          ItemContainerStyle="{StaticResource ReXGlueComboBoxItemStyle}"/>
            </StackPanel>
            <Button x:Name="buttonFetchOnce" Content="Fetch Once (codegen)" Click="ButtonFetchOnce_Click" Margin="0,0,0,6"
                    Height="28" Background="#3F3F46" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="buttonToggleAuto" Content="Auto Cycle: Off" Click="ButtonToggleAuto_Click" Margin="0,0,0,8"
                    Height="28" Background="#3F3F46" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand"/>

            <!-- Run Code Generation (full-width bar like desktop) -->
            <Button x:Name="buttonRunCodeGen" Content="Run Code Generation" Click="ButtonRunCodeGen_Click" Margin="0,8,0,0"
                    Height="42" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Background="#2D2D30" Foreground="#A0A0A0" BorderThickness="0" Cursor="Hand" FontSize="13" FontFamily="Segoe UI"/>

            <!-- Output (in-tool only) -->
            <TextBlock Text="Output" Foreground="#CCCCCC" FontSize="12" Margin="0,12,0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button x:Name="buttonClearOutput" Content="Clear" Click="ButtonClearOutput_Click" Margin="0,0,6,0"
                        Height="24" Width="60" Background="#3F3F46" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
            <Border Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1" Margin="0,0,0,0" MinHeight="80" MaxHeight="200">
                <RichTextBox x:Name="richTextBoxOutput" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="10"
                             Padding="6" BorderThickness="0" Background="#1E1E1E" Foreground="#CCCCCC"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
