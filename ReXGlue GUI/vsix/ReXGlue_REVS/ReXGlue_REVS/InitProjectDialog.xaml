<Window x:Class="ReXGlue_REVS.InitProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Initialize New Project"
        Width="480" Height="320" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">
    <StackPanel Margin="24,20">
        <TextBlock Text="Initialize New Project" Foreground="#4A9EFF" FontSize="15"
                   FontFamily="Segoe UI Semibold" Margin="0,0,0,6"/>
        <TextBlock Text="Creates a new ReXGlue application project using rexglue init."
                   Foreground="#666666" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,20"/>

        <TextBlock Text="Root Folder" Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,6"/>
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="76"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="textBoxRoot" Grid.Column="0" Height="28" Padding="6,4"
                     Background="#252525" Foreground="#D4D4D4" BorderBrush="#3A3A3A"
                     VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="Browse" Height="28" Padding="8,0"
                    Background="#252525" Foreground="#CCCCCC" BorderBrush="#3A3A3A"
                    Click="Browse_Click"/>
        </Grid>

        <TextBlock Text="Application Name" Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,6"/>
        <TextBox x:Name="textBoxAppName" Height="28" Padding="6,4" Margin="0,0,0,6"
                 Background="#252525" Foreground="#D4D4D4" BorderBrush="#3A3A3A"
                 VerticalContentAlignment="Center"/>
        <TextBlock x:Name="textFullPath" Text="Full path: (fill in root and name above)"
                   Foreground="#555555" FontSize="11" Margin="0,0,0,20"/>

        <Button x:Name="buttonInit" Content="Initialize Project" Height="36" FontSize="13"
                Background="#252525" Foreground="#CCCCCC" BorderBrush="#3A3A3A"
                Click="Initialize_Click"/>
    </StackPanel>
</Window>
