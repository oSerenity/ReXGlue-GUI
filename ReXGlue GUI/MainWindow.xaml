<Window x:Class="ReXGlue_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ReXGlue GUI"
        Height="700" Width="1100"
        MinHeight="480" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1C"
        KeyDown="Window_KeyDown">

    <Window.Resources>

        <!-- Nav tab RadioButton -->
        <Style x:Key="NavTabBtn" TargetType="RadioButton">
            <Setter Property="Foreground"        Value="#888888"/>
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Padding"           Value="16,0"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="content"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Rectangle x:Name="underline" Height="2" VerticalAlignment="Bottom"
                                       Fill="Transparent"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="content"   Property="TextElement.Foreground" Value="#4A9EFF"/>
                                <Setter TargetName="underline" Property="Fill"                   Value="#4A9EFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="content" Property="TextElement.Foreground" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small toolbar button -->
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2A2A2A"/>
            <Setter Property="Foreground"      Value="#CCCCCC"/>
            <Setter Property="BorderBrush"     Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#383838"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button (top-right) -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Background"      Value="#252525"/>
            <Setter Property="Foreground"      Value="#AAAAAA"/>
            <Setter Property="BorderBrush"     Value="#383838"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark TextBox -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="#141414"/>
            <Setter Property="Foreground"               Value="#CCCCCC"/>
            <Setter Property="CaretBrush"               Value="#4A9EFF"/>
            <Setter Property="BorderBrush"              Value="#333333"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="26"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="FontFamily"               Value="Consolas"/>
            <Setter Property="Padding"                  Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#4A9EFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Template chip button -->
        <Style x:Key="ChipBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2A2A2A"/>
            <Setter Property="Foreground"      Value="#CCCCCC"/>
            <Setter Property="BorderBrush"     Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="24"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#383838"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- X close chip button -->
        <Style x:Key="ChipClose" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#888888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="18"/>
            <Setter Property="Height"          Value="18"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FF6666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section expand toggle -->
        <Style x:Key="SectionToggle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#888888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Run button at bottom -->
        <Style x:Key="RunBtn" TargetType="Button">
            <Setter Property="Background"      Value="#252525"/>
            <Setter Property="Foreground"      Value="#CCCCCC"/>
            <Setter Property="BorderBrush"     Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E2E2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- StatusOk / StatusWarn -->
        <Style x:Key="StatusOk"   TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4CAF50"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="StatusWarn" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9800"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

    </Window.Resources>

    <Grid Background="#1C1C1C">
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>   <!-- top nav bar -->
            <RowDefinition Height="1"/>    <!-- separator -->
            <RowDefinition Height="*"/>    <!-- content -->
        </Grid.RowDefinitions>

        <!-- ══ TOP NAV BAR ══ -->
        <Grid Grid.Row="0" Background="#1C1C1C">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <RadioButton x:Name="tabBtnNewProject"  Content="New Project"
                             Style="{StaticResource NavTabBtn}"
                             IsChecked="True" GroupName="tabs"
                             Checked="TabBtn_Checked" Tag="NewProject"/>
                <RadioButton x:Name="tabBtnCodeGen"     Content="Code Generation"
                             Style="{StaticResource NavTabBtn}"
                             GroupName="tabs"
                             Checked="TabBtn_Checked" Tag="CodeGen"/>
                <RadioButton x:Name="tabBtnAddrParser"  Content="Address Parser"
                             Style="{StaticResource NavTabBtn}"
                             GroupName="tabs"
                             Checked="TabBtn_Checked" Tag="AddrParser"/>
                <RadioButton x:Name="tabBtnOutput"      Content="Output"
                             Style="{StaticResource NavTabBtn}"
                             GroupName="tabs"
                             Checked="TabBtn_Checked" Tag="Output"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,10,0">
                <Button x:Name="buttonTheme"   Style="{StaticResource IconBtn}"
                        Content="🌙" ToolTip="Toggle theme"
                        Margin="0,0,6,0" Click="buttonTheme_Click"/>
                <Button x:Name="buttonRefresh" Style="{StaticResource IconBtn}"
                        Content="↺" ToolTip="Refresh env vars"
                        Margin="0,0,6,0" Click="buttonRefresh_Click"/>
                <Button x:Name="buttonResetTemplates" Style="{StaticResource IconBtn}"
                        Content="⟲" ToolTip="Reset templates to defaults"
                        Click="buttonResetTemplates_Click"/>
            </StackPanel>
        </Grid>

        <Rectangle Grid.Row="1" Fill="#333333"/>

        <!-- ══ CONTENT ══ -->
        <Grid Grid.Row="2">

            <!-- ─── NEW PROJECT ─── -->
            <Grid x:Name="panelNewProject" Visibility="Visible">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                MaxWidth="520" Margin="0,60,0,40">
                        <Border Background="#242424" BorderBrush="#333333"
                                BorderThickness="1" CornerRadius="8" Padding="28,24">
                            <StackPanel>
                                <TextBlock Text="Initialize New Project"
                                           Foreground="#4A9EFF" FontSize="15"
                                           FontFamily="Segoe UI Semibold" Margin="0,0,0,6"/>
                                <TextBlock Text="Creates a new ReXGlue application project using  rexglue init."
                                           Foreground="#666666" FontSize="12" FontFamily="Segoe UI"
                                           TextWrapping="Wrap" Margin="0,0,0,20"/>

                                <TextBlock Text="Root Folder" Foreground="#CCCCCC"
                                           FontSize="13" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="76"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" x:Name="textBoxNewProjectRoot"
                                             Style="{StaticResource DarkTextBox}" Height="28"/>
                                    <Button  Grid.Column="2" Content="Browse"
                                             Style="{StaticResource ToolbarBtn}" Height="28"
                                             Click="buttonNewBrowse_Click"/>
                                </Grid>

                                <TextBlock Text="Application Name" Foreground="#CCCCCC"
                                           FontSize="13" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,6">
                                    <TextBox x:Name="textBoxAppName"
                                             Style="{StaticResource DarkTextBox}" Height="28"
                                             TextChanged="textBoxAppName_TextChanged"/>
                                    <TextBlock x:Name="placeholderAppName" Text="e.g. my-game"
                                               Foreground="#444444" FontFamily="Segoe UI" FontSize="12"
                                               Margin="7,0,0,0" VerticalAlignment="Center"
                                               IsHitTestVisible="False"/>
                                </Grid>
                                <TextBlock x:Name="textFullPath"
                                           Text="Full path: (fill in root and name above)"
                                           Foreground="#555555" FontSize="11" FontFamily="Segoe UI"
                                           Margin="0,0,0,20"/>

                                <Button Content="Initialize Project"
                                        Background="#252525" Foreground="#CCCCCC"
                                        BorderBrush="#3A3A3A" BorderThickness="1"
                                        Height="36" FontSize="13" FontFamily="Segoe UI"
                                        Cursor="Hand" Click="buttonInitProject_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ─── CODE GENERATION ─── -->
            <Grid x:Name="panelCodeGen" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Dir row -->
                    <RowDefinition Height="Auto"/>  <!-- File row -->
                    <RowDefinition Height="1"/>     <!-- separator -->
                    <RowDefinition Height="Auto"/>  <!-- path breadcrumb + toolbar -->
                    <RowDefinition Height="Auto"/>  <!-- Starter Templates -->
                    <RowDefinition Height="Auto"/>  <!-- Custom Templates -->
                    <RowDefinition Height="Auto"/>  <!-- Backup row -->
                    <RowDefinition Height="Auto"/>  <!-- VS Debugger row -->
                    <RowDefinition Height="1"/>     <!-- separator -->
                    <RowDefinition Height="Auto"/>  <!-- Find/Replace bar -->
                    <RowDefinition Height="*"/>     <!-- editor -->
                    <RowDefinition Height="Auto"/>  <!-- status bar -->
                    <RowDefinition Height="42"/>    <!-- Run button -->
                </Grid.RowDefinitions>

                <!-- Dir row -->
                <Grid Grid.Row="0" Background="#1C1C1C" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Dir:" Foreground="#888888"
                               FontFamily="Segoe UI" FontSize="12"
                               VerticalAlignment="Center" Margin="10,0,8,0"/>
                    <TextBox   Grid.Column="1" x:Name="textBoxCodeGenDir"
                               Style="{StaticResource DarkTextBox}"
                               Margin="0,5,0,5"
                               TextChanged="textBoxCodeGenDir_TextChanged"/>
                    <Button    Grid.Column="2" Content="Browse"
                               Style="{StaticResource ToolbarBtn}"
                               Margin="6,0,4,0" Click="buttonCodeGenDirBrowse_Click"/>
                    <Button    Grid.Column="3" Content="Scan .toml"
                               Style="{StaticResource ToolbarBtn}"
                               Margin="0,0,10,0" Click="buttonScanToml_Click"/>
                </Grid>

                <!-- File row -->
                <Grid Grid.Row="1" Background="#1C1C1C">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="File:" Foreground="#888888"
                               FontFamily="Segoe UI" FontSize="12"
                               VerticalAlignment="Center" Margin="10,0,8,0"/>
                    <TextBox   Grid.Column="1" x:Name="textBoxCodeGenFile"
                               Style="{StaticResource DarkTextBox}"
                               Margin="0,5,0,5"
                               TextChanged="textBoxCodeGenFile_TextChanged"/>
                    <Button    Grid.Column="2" Content="Browse"
                               Style="{StaticResource ToolbarBtn}"
                               Margin="6,0,10,0" Click="buttonCodeGenFileBrowse_Click"/>
                </Grid>

                <Rectangle Grid.Row="2" Fill="#2A2A2A"/>

                <!-- Breadcrumb + action toolbar -->
                <Grid Grid.Row="3" Background="#1C1C1C" Margin="10,4,10,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="textBreadcrumb" Grid.Column="0"
                               Foreground="#666666" FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Reload"            Style="{StaticResource ToolbarBtn}" Margin="0,0,4,0" Click="buttonReload_Click"/>
                        <Button Content="Save"              Style="{StaticResource ToolbarBtn}" Margin="0,0,4,0" Click="buttonSave_Click"/>
                        <Button Content="+ setjmp/longjmp"  Style="{StaticResource ToolbarBtn}" Margin="0,0,4,0" Click="buttonAddSetjmp_Click"/>
                        <Button Content="Remove Dupes"      Style="{StaticResource ToolbarBtn}" Margin="0,0,4,0" Click="buttonRemoveDupes_Click"/>
                        <Button x:Name="buttonClearValues" Content="Clear Values ▾" Style="{StaticResource ToolbarBtn}" Margin="0,0,4,0" Click="buttonClearValues_Click">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="clearValuesContextMenu">
                                    <MenuItem Header="All"    Tag="All"    Click="ClearValuesMenu_Click"/>
                                    <MenuItem Header="Name"   Tag="Name"   Click="ClearValuesMenu_Click"/>
                                    <MenuItem Header="Parent" Tag="Parent" Click="ClearValuesMenu_Click"/>
                                    <MenuItem Header="Size"   Tag="Size"   Click="ClearValuesMenu_Click"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button Content="Write [functions]" Style="{StaticResource ToolbarBtn}" Margin="0,0,4,0" Click="buttonWriteFunctions_Click"/>
                        <Button Content="Add addr = {}"     Style="{StaticResource ToolbarBtn}" Margin="0,0,4,0" Click="buttonAddFunctionAddress_Click"/>
                        <Button Content="Write [rexcrt]"    Style="{StaticResource ToolbarBtn}" Margin="0,0,0,0" Click="buttonWriteRexcrt_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Starter Templates section -->
                <StackPanel Grid.Row="4" Margin="10,4,10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button x:Name="btnToggleStarter" Content="▾ Starter Templates"
                                Style="{StaticResource SectionToggle}"
                                Click="btnToggleStarter_Click"/>
                    </StackPanel>
                    <WrapPanel x:Name="panelStarterTemplates" Orientation="Horizontal">
                        <!-- Chips populated from code-behind -->
                    </WrapPanel>
                </StackPanel>

                <!-- Custom Templates section -->
                <StackPanel Grid.Row="5" Margin="10,6,10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button x:Name="btnToggleCustom" Content="▾ Custom Templates"
                                Style="{StaticResource SectionToggle}"
                                Click="btnToggleCustom_Click"/>
                        <Button Content="+"
                                Style="{StaticResource ToolbarBtn}"
                                Width="22" Padding="0"
                                Margin="6,0,0,0"
                                Click="buttonAddCustomTemplate_Click"/>
                    </StackPanel>
                    <WrapPanel x:Name="panelCustomTemplates" Orientation="Horizontal">
                        <!-- Chips populated from code-behind -->
                    </WrapPanel>
                </StackPanel>

                <!-- Backup row -->
                <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="10,8,10,6">
                    <TextBlock Text="Backup:" Foreground="#888888"
                               FontFamily="Segoe UI" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="Save Backup"   Style="{StaticResource ToolbarBtn}" Margin="0,0,6,0" Click="buttonSaveBackup_Click"/>
                    <Button Content="Load Backup"   Style="{StaticResource ToolbarBtn}" Click="buttonLoadBackup_Click"/>
                </StackPanel>

                <!-- VS Debugger — ctx.ctr.u32 -->
                <Border Grid.Row="7" Background="#161B22" BorderBrush="#2D3748"
                        BorderThickness="0,1,0,1" Padding="10,6,10,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Label + status dot -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Ellipse x:Name="ellipseVsDot" Width="7" Height="7"
                                     Fill="#444444" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="VS Debugger" Foreground="#6A8EAE"
                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="ctx.ctr.u32 →" Foreground="#444D5A"
                                       FontFamily="Consolas" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="textBoxVsExpression"
                                     Text="ctx.ctr.u32"
                                     Style="{StaticResource DarkTextBox}"
                                     Width="130" Height="22"
                                     FontSize="11"
                                     TextChanged="textBoxVsExpression_TextChanged"/>
                        </StackPanel>

                        <!-- Status message -->
                        <TextBlock x:Name="textBlockVsStatus"
                                   Grid.Column="1"
                                   Text="Idle — pause VS debugger at a breakpoint first."
                                   Foreground="#4A5568"
                                   FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Action buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="poll (s):" Foreground="#4A5568"
                                       FontFamily="Segoe UI" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="textBoxVsPollInterval"
                                     Text="3" Width="30"
                                     Style="{StaticResource DarkTextBox}"
                                     Height="22" FontSize="11"/>
                            <Button Content="⬇ Fetch"
                                    Style="{StaticResource ToolbarBtn}"
                                    Height="22" FontSize="11" Padding="8,0"
                                    Margin="6,0,4,0"
                                    ToolTip="Connect to VS, read ctx.ctr.u32, inject into [functions]"
                                    Click="VsDebugger_FetchOnce"/>
                            <ToggleButton x:Name="toggleVsPoll"
                                          Content="▶ Auto"
                                          Height="22" FontSize="11" Padding="8,0"
                                          FontFamily="Segoe UI" Cursor="Hand"
                                          Checked="VsDebugger_StartPolling"
                                          Unchecked="VsDebugger_StopPolling"
                                          ToolTip="Poll VS every N seconds automatically">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Background"   Value="#2A2A2A"/>
                                        <Setter Property="Foreground"   Value="#CCCCCC"/>
                                        <Setter Property="BorderBrush"  Value="#3A3A3A"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="Background"  Value="#1A3A1A"/>
                                                            <Setter Property="BorderBrush" Value="#4EC94E"/>
                                                            <Setter Property="Foreground"  Value="#4EC94E"/>
                                                            <Setter Property="Content"     Value="■ Stop"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#383838"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                        </StackPanel>
                    </Grid>
                </Border>

                <Rectangle Grid.Row="8" Fill="#1E1E1E"/>

                <!-- Find / Replace bar (hidden until Ctrl+F / Ctrl+H) -->
                <Border x:Name="findBar" Grid.Row="9"
                        Background="#252526" BorderBrush="#3C3C3C"
                        BorderThickness="0,0,0,1"
                        Visibility="Collapsed" Padding="8,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Find -->
                        <TextBlock Grid.Column="0" Text="Find:" Foreground="#CCCCCC"
                                   FontFamily="Segoe UI" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox   Grid.Column="1" x:Name="textBoxFind"
                                   Style="{StaticResource DarkTextBox}" Height="24"
                                   KeyDown="textBoxFind_KeyDown"
                                   TextChanged="textBoxFind_TextChanged"/>

                        <!-- Replace -->
                        <TextBlock Grid.Column="2" x:Name="labelReplace"
                                   Text="Replace:" Foreground="#CCCCCC"
                                   FontFamily="Segoe UI" FontSize="12"
                                   VerticalAlignment="Center" Margin="10,0,6,0"
                                   Visibility="Collapsed"/>
                        <TextBox   Grid.Column="3" x:Name="textBoxReplace"
                                   Style="{StaticResource DarkTextBox}" Height="24"
                                   Visibility="Collapsed"
                                   KeyDown="textBoxReplace_KeyDown"/>

                        <!-- Buttons -->
                        <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8,0,0,0">
                            <Button Content="↑" Style="{StaticResource ToolbarBtn}"
                                    Width="26" Padding="0" Margin="0,0,3,0"
                                    ToolTip="Previous match (Shift+Enter)"
                                    Click="buttonFindPrev_Click"/>
                            <Button Content="↓" Style="{StaticResource ToolbarBtn}"
                                    Width="26" Padding="0" Margin="0,0,3,0"
                                    ToolTip="Next match (Enter)"
                                    Click="buttonFindNext_Click"/>
                            <Button x:Name="buttonReplaceOne" Content="Replace"
                                    Style="{StaticResource ToolbarBtn}"
                                    Margin="0,0,3,0" Visibility="Collapsed"
                                    Click="buttonReplaceOne_Click"/>
                            <Button x:Name="buttonReplaceAll" Content="Replace All"
                                    Style="{StaticResource ToolbarBtn}"
                                    Margin="0,0,3,0" Visibility="Collapsed"
                                    Click="buttonReplaceAll_Click"/>
                        </StackPanel>

                        <!-- Match info -->
                        <TextBlock Grid.Column="5" x:Name="textFindInfo"
                                   Foreground="#888888" FontFamily="Segoe UI" FontSize="11"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>

                        <!-- Close -->
                        <Button Grid.Column="6" Content="✕"
                                Style="{StaticResource ToolbarBtn}"
                                Width="24" Padding="0"
                                ToolTip="Close (Escape)"
                                Click="buttonFindClose_Click"/>
                    </Grid>
                </Border>

                <!-- TOML editor — VS Code style -->
                <Grid Grid.Row="10" Background="#1E1E1E">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52"/>  <!-- gutter -->
                        <ColumnDefinition Width="1"/>   <!-- gutter border -->
                        <ColumnDefinition Width="*"/>   <!-- editor -->
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1E1E1E"/>
                    <Rectangle Grid.Column="1" Fill="#2A2A2A"/>

                    <ScrollViewer Grid.Column="0" Grid.ColumnSpan="3"
                                  x:Name="editorScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Background="#1E1E1E"
                                  Padding="0"
                                  PreviewMouseWheel="editorScrollViewer_PreviewMouseWheel">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Width" Value="10"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ScrollBar">
                                            <Grid Background="#1E1E1E">
                                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                    <Track.Thumb>
                                                        <Thumb>
                                                            <Thumb.Template>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="#424242" CornerRadius="5" Margin="2"/>
                                                                </ControlTemplate>
                                                            </Thumb.Template>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ScrollViewer.Resources>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#1E1E1E" Padding="0,8,0,8">
                                <ItemsControl x:Name="lineNumbersList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="#4A4A4A"
                                                       FontFamily="Consolas" FontSize="13"
                                                       Height="20"
                                                       TextAlignment="Right"
                                                       Padding="0,0,12,0"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <RichTextBox x:Name="textBoxTomlEditor"
                                         Grid.Column="1"
                                         Background="#1E1E1E"
                                         Foreground="#D4D4D4"
                                         CaretBrush="#AEAFAD"
                                         SelectionBrush="#264F78"
                                         BorderThickness="0"
                                         FontFamily="Consolas" FontSize="13"
                                         AcceptsTab="True"
                                         HorizontalScrollBarVisibility="Hidden"
                                         VerticalScrollBarVisibility="Hidden"
                                         Padding="4,8,8,8"
                                         TextChanged="textBoxTomlEditor_TextChanged"
                                         PreviewKeyDown="textBoxTomlEditor_PreviewKeyDown">
                                <RichTextBox.Resources>
                                    <Style TargetType="Paragraph">
                                        <Setter Property="Margin"     Value="0"/>
                                        <Setter Property="LineHeight" Value="20"/>
                                    </Style>
                                </RichTextBox.Resources>
                            </RichTextBox>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <!-- Status bar -->
                <Border Grid.Row="11" Background="#007ACC" Padding="10,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="textStatusLeft"
                                   Grid.Column="0" Foreground="White"
                                   FontFamily="Segoe UI" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock x:Name="textStatusCursor"
                                       Foreground="White" FontFamily="Segoe UI" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock x:Name="textStatusEncoding"
                                       Text="UTF-8" Foreground="White"
                                       FontFamily="Segoe UI" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock x:Name="textStatusLang"
                                       Text="TOML" Foreground="White"
                                       FontFamily="Segoe UI" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Run Code Generation button -->
                <Button Grid.Row="12" Content="Run Code Generation"
                        Style="{StaticResource RunBtn}"
                        Click="buttonRunCodeGen_Click"/>
            </Grid>

            <!-- ─── ADDRESS PARSER ─── -->
            <Grid x:Name="panelAddrParser" Visibility="Collapsed">
                <Grid Margin="10,10,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Extract unique PowerPC branch addresses from crash logs / call traces.&#x0a;Parses lines containing &quot; from 0x...&quot; and outputs them as  ADDR = {}"
                               Foreground="#666666" FontSize="12" FontFamily="Segoe UI"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Rectangle Grid.Row="1" Height="1" Fill="#2A2A2A" Margin="0,0,0,10"/>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Input"
                                       Foreground="#888888" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Paste from Clipboard"
                                    Style="{StaticResource ToolbarBtn}" Height="26"
                                    Click="buttonAddrPaste_Click"/>
                        </Grid>
                        <TextBox Grid.Row="1" x:Name="textBoxAddress"
                                 Background="#141414" Foreground="#CCCCCC"
                                 BorderBrush="#333333" BorderThickness="1"
                                 FontFamily="Consolas" FontSize="12"
                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="10"/>
                    </Grid>

                    <Button Grid.Row="3" Content="Parse Addresses"
                            Style="{StaticResource ToolbarBtn}" Height="34"
                            HorizontalAlignment="Center" Margin="0,10,0,10"
                            Click="buttonParseAddress_Click"/>

                    <Grid Grid.Row="4" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Output (ADDRESS = {})"
                                   Foreground="#888888" FontFamily="Segoe UI" FontSize="12"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Copy to Clipboard"
                                Style="{StaticResource ToolbarBtn}" Height="26"
                                Click="buttonAddrCopy_Click"/>
                    </Grid>

                    <RichTextBox Grid.Row="5" x:Name="textBoxAddressResult"
                             Background="#141414" Foreground="#CCCCCC"
                             BorderBrush="#333333" BorderThickness="1"
                             FontFamily="Consolas" FontSize="12"
                             IsReadOnly="True"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10"/>
                </Grid>
            </Grid>

            <!-- ─── OUTPUT ─── -->
            <Grid x:Name="panelOutput" Visibility="Collapsed" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Background="#1A1A1A">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Raw command output — select and copy lines to feed into Address Parser."
                               Foreground="#555555" FontFamily="Segoe UI" FontSize="11"
                               VerticalAlignment="Center" Margin="16,0,10,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,6,10,6">
                        <Button Content="Copy All" Style="{StaticResource ToolbarBtn}" Margin="0,0,6,0" Click="buttonOutputCopyAll_Click"/>
                        <Button Content="Send to Address Parser" Style="{StaticResource ToolbarBtn}" Margin="0,0,6,0" Click="buttonOutputSendToParser_Click"/>
                        <Button Content="Clear" Style="{StaticResource ToolbarBtn}" Click="buttonOutputClear_Click"/>
                    </StackPanel>
                </Grid>
                <RichTextBox Grid.Row="1" x:Name="textBoxOutput"
                             Background="#0D0D0D" Foreground="#CCCCCC"
                             BorderThickness="0"
                             FontFamily="Consolas" FontSize="12"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10"/>
            </Grid>

            <!-- ─── SDK SETUP OVERLAY ─── -->
            <Grid x:Name="panelSdkSetup" Visibility="Collapsed"
                  Background="#CC000000" Panel.ZIndex="100">
                <Border Background="#242424" BorderBrush="#383838" BorderThickness="1"
                        CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Padding="32,28" MinWidth="480">
                    <StackPanel>
                        <TextBlock Text="SDK Setup Required"
                                   Foreground="#4A9EFF" FontSize="16" FontFamily="Segoe UI Semibold"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="textSdkSetupMessage"
                                   Foreground="#666666" FontSize="12" FontFamily="Segoe UI"
                                   TextWrapping="Wrap" Margin="0,0,0,16"
                                   Text="Select the parent folder that contains 'rexglue-sdk'."/>

                        <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1"
                                CornerRadius="4" Padding="12,10" Margin="0,0,0,16">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock DockPanel.Dock="Left" Text="REXSDK"
                                               Foreground="#888888" FontFamily="Segoe UI"
                                               FontSize="12" Width="110"/>
                                    <TextBlock x:Name="statusRexsdk" Text="● Not set"
                                               Style="{StaticResource StatusWarn}"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock DockPanel.Dock="Left" Text="Path entry"
                                               Foreground="#888888" FontFamily="Segoe UI"
                                               FontSize="12" Width="110"/>
                                    <TextBlock x:Name="statusPathEntry" Text="● Not set"
                                               Style="{StaticResource StatusWarn}"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" Text="BaseSDKPath"
                                               Foreground="#888888" FontFamily="Segoe UI"
                                               FontSize="12" Width="110"/>
                                    <TextBlock x:Name="statusBaseSdk" Text="● Not set"
                                               Style="{StaticResource StatusWarn}"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Base Folder" Foreground="#CCCCCC"
                                   FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="76"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="textBoxSetupBaseFolder"
                                     Style="{StaticResource DarkTextBox}" Height="28"
                                     TextChanged="textBoxSetupBaseFolder_TextChanged"/>
                            <Button  Grid.Column="2" Content="Browse"
                                     Style="{StaticResource ToolbarBtn}" Height="28"
                                     Click="buttonSetupBrowse_Click"/>
                        </Grid>

                        <TextBlock Text="REXSDK will be set to:"
                                   Foreground="#888888" FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                        <TextBox x:Name="textBoxSetupPreviewRexsdk"
                                 Background="#141414" Foreground="#666666"
                                 BorderBrush="#333333" BorderThickness="1"
                                 FontFamily="Consolas" FontSize="11"
                                 IsReadOnly="True" Height="26" Padding="6,0"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,8"/>

                        <TextBlock Text="Path entry will be added:"
                                   Foreground="#888888" FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                        <TextBox x:Name="textBoxSetupPreviewPath"
                                 Background="#141414" Foreground="#666666"
                                 BorderBrush="#333333" BorderThickness="1"
                                 FontFamily="Consolas" FontSize="11"
                                 IsReadOnly="True" Height="26" Padding="6,0"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Cancel &amp; Close"
                                    Style="{StaticResource ToolbarBtn}" Height="32"
                                    Click="buttonSetupCancel_Click"/>
                            <Button Grid.Column="2" Content="Apply &amp; Continue"
                                    Height="32" Cursor="Hand"
                                    Background="#1A3A5A" Foreground="#4A9EFF"
                                    BorderBrush="#4A9EFF" BorderThickness="1"
                                    FontSize="12" FontFamily="Segoe UI"
                                    Click="buttonSetupApply_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>
